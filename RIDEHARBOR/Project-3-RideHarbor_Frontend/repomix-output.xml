<file path="css/admin.css">
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap');

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Inter", sans-serif;
}

:root {
    --gold: #D4AF37;
    --gold-dim: rgba(212, 175, 55, 0.15);
    --gold-glow: rgba(212, 175, 55, 0.08);
    --bg-base: #0a0a0a;
    --bg-card: rgba(255, 255, 255, 0.03);
    --bg-card-hover: rgba(212, 175, 55, 0.06);
    --border: rgba(212, 175, 55, 0.12);
    --border-active: rgba(212, 175, 55, 0.5);
    --text-primary: #f0f0f0;
    --text-muted: #888;
    --text-dim: #555;
    --sidebar-width: 240px;
    --topbar-height: 70px;
}

body {
    background-color: var(--bg-base);
    color: var(--text-primary);
    min-height: 100vh;
    overflow-x: hidden;
}

/* ── Layout Shell ─────────────────────────────────── */
.admin-container {
    display: flex;
    min-height: 100vh;
    overflow-x: hidden;
}

/* ── Sidebar ──────────────────────────────────────── */
.sidebar {
    width: var(--sidebar-width);
    background: rgba(10, 10, 10, 0.97);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 0;
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    z-index: 100;
    transition: transform 0.3s ease;
}

.brand {
    padding: 28px 22px 22px;
    border-bottom: 1px solid var(--border);
}

.brand h1 {
    font-family: "Space Mono", monospace;
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    letter-spacing: 2px;
    line-height: 1;
}

.brand h1 span {
    color: var(--gold);
}

.brand p {
    color: var(--text-dim);
    margin-top: 6px;
    font-size: 10px;
    letter-spacing: 3px;
    font-weight: 500;
    text-transform: uppercase;
}

.menu {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 20px 14px;
    flex: 1;
}

.menu-label {
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--text-dim);
    text-transform: uppercase;
    padding: 0 8px;
    margin: 10px 0 6px;
    font-weight: 600;
}

.menu button {
    background: transparent;
    color: var(--text-muted);
    border: none;
    padding: 11px 14px;
    border-radius: 8px;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 13.5px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
    position: relative;
}

.menu button .icon {
    width: 18px;
    height: 18px;
    opacity: 0.6;
    flex-shrink: 0;
}

.menu button:hover {
    background: var(--bg-card-hover);
    color: var(--text-primary);
}

.menu button:hover .icon {
    opacity: 1;
}

.menu button.active {
    background: var(--gold-dim);
    color: var(--gold);
    font-weight: 600;
}

.menu button.active .icon {
    opacity: 1;
}

.menu button.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    height: 60%;
    width: 3px;
    background: var(--gold);
    border-radius: 0 2px 2px 0;
}

.sidebar-footer {
    padding: 18px 20px;
    border-top: 1px solid var(--border);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.5px;
}

/* ── Main Content ─────────────────────────────────── */
.main-content {
    overflow-x: hidden;
    flex: 1;
    margin-left: var(--sidebar-width);
    width: calc(100% - var(--sidebar-width));
    display: flex;
    flex-direction: column;
    min-height: 100vh;
}

/* ── Topbar ───────────────────────────────────────── */
.topbar {
    height: var(--topbar-height);
    background: rgba(10, 10, 10, 0.95);
    border-bottom: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 30px;
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(10px);
    gap: 16px;
}

.topbar-left h2 {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1;
}

.topbar-left h2 span {
    color: var(--gold);
}

.topbar-left p {
    color: var(--text-muted);
    font-size: 12px;
    margin-top: 4px;
}

.topbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
}

.admin-badge {
    background: var(--gold-dim);
    border: 1px solid rgba(212, 175, 55, 0.3);
    color: var(--gold);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.5px;
    white-space: nowrap;
}

.status-dot {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-muted);
    white-space: nowrap;
}

.status-dot::before {
    content: '';
    width: 7px;
    height: 7px;
    background: #22c55e;
    border-radius: 50%;
    box-shadow: 0 0 6px rgba(34, 197, 94, 0.6);
    flex-shrink: 0;
}

/* ── Page Body ────────────────────────────────────── */
.page-body {
    padding: 28px 30px;
    flex: 1;
}

/* ── Summary Cards ────────────────────────────────── */
.cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
}

.card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 20px 22px;
    transition: border-color 0.2s ease, background 0.2s ease;
    position: relative;
    overflow: hidden;
}

.card::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.card:hover {
    border-color: var(--border-active);
    background: var(--bg-card-hover);
}

.card:hover::after {
    opacity: 1;
}

.card-label {
    color: var(--text-muted);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 10px;
}

.card .value {
    font-size: 28px;
    font-weight: 700;
    color: var(--text-primary);
    font-family: "Space Mono", monospace;
    line-height: 1;
}

.card .value.highlight {
    color: var(--gold);
}

.card-sub {
    font-size: 11px;
    color: var(--text-dim);
    margin-top: 6px;
}

/* ── Panel ────────────────────────────────────────── */
.panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
}

.panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 22px;
    border-bottom: 1px solid var(--border);
    gap: 16px;
    flex-wrap: wrap;
}

.panel-title-group {
    display: flex;
    align-items: center;
    gap: 10px;
}

.panel-header h3 {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-primary);
}

.record-count {
    background: var(--gold-dim);
    color: var(--gold);
    font-size: 11px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
    font-family: "Space Mono", monospace;
}

.search-box {
    position: relative;
    display: flex;
    align-items: center;
}

.search-box svg {
    position: absolute;
    left: 11px;
    color: var(--text-dim);
    pointer-events: none;
}

.search-box input {
    padding: 9px 12px 9px 34px;
    width: 240px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    outline: none;
    border-radius: 8px;
    color: var(--text-primary);
    font-size: 13px;
    transition: border-color 0.2s ease;
}

.search-box input::placeholder {
    color: var(--text-dim);
}

.search-box input:focus {
    border-color: rgba(212, 175, 55, 0.4);
    background: rgba(212, 175, 55, 0.04);
}

/* ── Table (Desktop default) ──────────────────────── */
.table-container {
    max-width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    width: 100%;
    display: block;
}

.table-container::-webkit-scrollbar {
    height: 4px;
}

.table-container::-webkit-scrollbar-track {
    background: transparent;
}

.table-container::-webkit-scrollbar-thumb {
    background: rgba(212, 175, 55, 0.25);
    border-radius: 4px;
}

.table-container::-webkit-scrollbar-thumb:hover {
    background: rgba(212, 175, 55, 0.5);
}

table {
    width: 100%;
    border-collapse: collapse;
    min-width: 900px;
    table-layout: fixed;
}

thead th {
    background: rgba(212, 175, 55, 0.07);
    color: var(--text-muted);
    font-size: 10.5px;
    padding: 12px 14px;
    text-align: left;
    font-weight: 600;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
}

tbody tr {
    transition: background 0.15s ease, opacity 0.3s ease, transform 0.3s ease;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
}

tbody tr:last-child {
    border-bottom: none;
}

tbody tr:hover {
    background: rgba(212, 175, 55, 0.05);
}

tbody td {
    padding: 12px 14px;
    color: #ccc;
    font-size: 12.5px;
    white-space: nowrap;
}

/* Column widths — compact fixed layout */
thead th,
tbody td {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

thead th:nth-child(1),
tbody td:nth-child(1) {
    width: 52px;
}

/* S.No */
thead th:nth-child(2),
tbody td:nth-child(2) {
    width: 110px;
}

/* Name */
thead th:nth-child(3),
tbody td:nth-child(3) {
    width: 170px;
}

/* Email */
thead th:nth-child(4),
tbody td:nth-child(4) {
    width: 105px;
}

/* Mobile */
thead th:nth-child(5),
tbody td:nth-child(5) {
    width: 130px;
}

/* Car */
thead th:nth-child(6),
tbody td:nth-child(6) {
    width: 90px;
}

/* Location */
thead th:nth-child(7),
tbody td:nth-child(7) {
    width: 100px;
}

/* Journey Date */
thead th:nth-child(8),
tbody td:nth-child(8) {
    width: 100px;
}

/* License No */
thead th:nth-child(9),
tbody td:nth-child(9) {
    width: 78px;
}

/* Duration */
thead th:nth-child(10),
tbody td:nth-child(10) {
    width: 68px;
}

/* Pickup */
thead th:nth-child(11),
tbody td:nth-child(11) {
    width: 68px;
}

/* Return */
thead th:nth-child(12),
tbody td:nth-child(12) {
    width: 80px;
}

/* Amount */
thead th:nth-child(13),
tbody td:nth-child(13) {
    width: 100px;
}

/* Txn ID */
thead th:nth-child(14),
tbody td:nth-child(14) {
    width: 80px;
    text-align: center;
}

/* Action */

/* Scroll hint for wide tables */
.table-container {
    position: relative;
}

.table-container::after {
    content: "← scroll →";
    display: none;
    text-align: center;
    font-size: 10px;
    color: var(--text-dim);
    letter-spacing: 2px;
    padding: 6px;
    border-top: 1px solid var(--border);
}

thead th:nth-child(14) {
    text-align: center;
}

.otp-cell {
    font-family: "Space Mono", monospace !important;
    font-size: 12px !important;
    color: var(--gold) !important;
    letter-spacing: 2px;
}

.amount-cell {
    font-weight: 600;
    color: var(--gold) !important;
}

.empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--text-dim);
    font-size: 14px;
}

/* ── Panel Footer ─────────────────────────────────── */
.panel-footer {
    padding: 12px 22px;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 11px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

/* ── Card View (mobile rows) ──────────────────────── */
.data-cards {
    display: none;
    flex-direction: column;
    gap: 1px;
    background: var(--border);
}

.data-card {
    background: #0e0e0e;
    padding: 14px 18px;
    transition: background 0.15s;
}

.data-card:hover {
    background: rgba(212, 175, 55, 0.04);
}

.data-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 10px;
}

.data-card-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
}

.data-card-id {
    font-family: "Space Mono", monospace;
    font-size: 10px;
    color: var(--text-dim);
    margin-top: 2px;
}

.data-card-badge {
    font-size: 11px;
    font-weight: 700;
    color: var(--gold);
    background: var(--gold-dim);
    padding: 3px 9px;
    border-radius: 12px;
    font-family: "Space Mono", monospace;
    flex-shrink: 0;
}

.data-card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 16px;
}

.data-card-label {
    font-size: 9.5px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 2px;
    font-weight: 600;
}

.data-card-value {
    font-size: 12.5px;
    color: #ccc;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* ── Mobile Overlay ───────────────────────────────── */
.sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: 90;
}

.hamburger {
    display: none;
    background: none;
    border: 1px solid var(--border);
    color: var(--text-primary);
    padding: 8px 10px;
    border-radius: 8px;
    cursor: pointer;
    flex-shrink: 0;
}

/* ── Delete Button ────────────────────────────────── */
.delete-btn {
    background: transparent;
    border: 1px solid rgba(220, 38, 38, 0.35);
    color: #f87171;
    padding: 5px 12px;
    border-radius: 6px;
    font-size: 11.5px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    font-family: "Inter", sans-serif;
    letter-spacing: 0.3px;
}

.delete-btn:hover {
    background: rgba(220, 38, 38, 0.12);
    border-color: #f87171;
    color: #fca5a5;
}

.delete-btn:active {
    transform: scale(0.96);
}

.card-delete-btn {
    margin-top: 12px;
    width: 100%;
    padding: 9px;
    border-radius: 8px;
    font-size: 12px;
}

/* Action column — don't truncate */
thead th:last-child,
tbody td:last-child {
    max-width: none;
    width: 90px;
    text-align: center;
}

/* ── 960px ────────────────────────────────────────── */
@media (max-width: 960px) {
    :root {
        --sidebar-width: 210px;
    }

    .cards {
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .card .value {
        font-size: 22px;
    }

    .topbar {
        padding: 0 20px;
    }

    .page-body {
        padding: 20px;
    }

    .search-box input {
        width: 200px;
    }

    /* Hide heavy columns */
    thead th:nth-child(3),
    tbody td:nth-child(3),
    thead th:nth-child(10),
    tbody td:nth-child(10) {
        display: none;
    }


    thead th:nth-child(3),
    tbody td:nth-child(3),
    thead th:nth-child(7),
    tbody td:nth-child(7) {
        display: none;
    }

}

/* ── 768px (sidebar becomes drawer) ──────────────── */
@media (max-width: 768px) {
    .sidebar {
        transform: translateX(-100%);
    }

    .sidebar.open {
        transform: translateX(0);
        box-shadow: 4px 0 30px rgba(0, 0, 0, 0.5);
    }

    .sidebar-overlay.visible {
        display: block;
    }

    .hamburger {
        display: flex;
        align-items: center;
    }

    .main-content {
        margin-left: 0;
    }

    .topbar-left p {
        display: none;
    }

    .cards {
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .search-box input {
        width: 180px;
    }
}

/* ── 560px (table → cards) ────────────────────────── */
@media (max-width: 560px) {
    .topbar {
        padding: 0 14px;
        height: 60px;
    }

    .topbar-left h2 {
        font-size: 15px;
    }

    .admin-badge {
        display: none;
    }

    .page-body {
        padding: 14px;
    }

    .cards {
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
        margin-bottom: 16px;
    }

    .card {
        padding: 14px;
    }

    .card-label {
        font-size: 9px;
    }

    .card .value {
        font-size: 17px;
    }

    .card-sub {
        display: none;
    }

    .panel-header {
        padding: 12px 16px;
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
    }

    .panel-header h3 {
        font-size: 14px;
    }

    .search-box {
        width: 100%;
    }

    .search-box input {
        width: 100%;
    }

    /* Hide table, show cards */
    .table-container {
        display: none;
    }

    .data-cards {
        display: flex;
    }

    .panel-footer {
        flex-direction: column;
        gap: 4px;
        text-align: center;
    }
}

@media (max-width: 1200px) {
    .table-container::after {
        display: block;
    }

    /* Hide least important columns on smaller laptops */
    thead th:nth-child(8),
    tbody td:nth-child(8),
    thead th:nth-child(9),
    tbody td:nth-child(9) {
        display: none;
    }
}
