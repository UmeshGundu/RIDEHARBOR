        transform: translateX(-60px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}
.mobile-nav-link:hover {
    color: #D4AF37;
}
.mobile-nav-link::before {
    content: "";
    display: inline-block;
    width: 0;
    height: 2px;
    background: #D4AF37;
    margin-right: 0;
    vertical-align: middle;
