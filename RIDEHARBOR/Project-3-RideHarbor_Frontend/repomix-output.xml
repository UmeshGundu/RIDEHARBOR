    background: linear-gradient(to right,
            transparent,
            rgba(212, 175, 55, 0.6),
            transparent);
}
/* 4 Equal Columns */
.models-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
}
/* Remove box feel */
.model-card {
    position: relative;
    overflow: hidden;
