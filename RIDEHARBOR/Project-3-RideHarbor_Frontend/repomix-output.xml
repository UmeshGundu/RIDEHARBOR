    transition: opacity 0.8s ease, visibility 0.8s ease;
}

/* Fade-out state */
#preloader.hide {
    opacity: 0;
    visibility: hidden;
}

/* Logo Layout */
.logo-container {
    display: flex;
    gap: 60px;
    justify-content: center;
    align-items: center;
}

/* Logo Standard Size */
.logo-container img {
    width: 110px;
    height: 70px;
    object-fit: contain;
    opacity: 0;
    transform: translateY(40px);
    animation: slideUp 1s ease forwards;
}

/* Animations */
@keyframes slideUp {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeText {
    to {
        opacity: 1;
    }
}

/* Delay each logo */
.logo-container img:nth-child(1) {
    animation-delay: 0.4s;
}

.logo-container img:nth-child(2) {
    animation-delay: 0.6s;
}

.logo-container img:nth-child(3) {
    animation-delay: 0.8s;
}

.logo-container img:nth-child(4) {
    animation-delay: 1s;
}

.logo-container img:nth-child(5) {
    animation-delay: 1.2s;
}

.logo-container img:nth-child(6) {
    animation-delay: 1.2s;
}

.logo-container img:nth-child(7) {
    animation-delay: 1.2s;
}

