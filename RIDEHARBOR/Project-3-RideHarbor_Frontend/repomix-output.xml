}
/* Footer stays behind */
.luxury-footer {
    position: sticky;
    bottom: 0;
    z-index: 1;
}
/* =========================================================*/
#bookingFormModal input,
#bookingFormModal select {
    width: 100%;
    margin-bottom: 12px;
    padding: 12px;
    background: #111;
