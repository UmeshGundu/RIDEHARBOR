}
/* ================ Models Section ================*/
#models-section {
    padding: 100px 8%;
    background: #0f0f0f;
}
#models-section::after {
    content: "";
    display: block;
    width: 80%;
    height: 1px;
    margin: 100px auto 0;
    background: linear-gradient(to right,
            transparent,
            rgba(212, 175, 55, 0.6),
            transparent);
}
/* 4 Equal Columns */
.models-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
}
/* Remove box feel */
.model-card {
    position: relative;
    overflow: hidden;
}
.model-card {
    transition: transform 0.4s ease, filter 0.4s ease;
}
.model-card:hover {
    transform: translateY(-8px);
    filter: brightness(1.05);
}
/* Image wrapper */
.image-wrapper {
