    }
    .logo {
        font-size: 22px;
    }
    .signin a {
        padding: 7px 14px;
        font-size: 13px;
    }
    .banner {
        height: 55vh;
        min-height: 360px;
    }
    .banner-content h1 {
        font-size: 62px;
