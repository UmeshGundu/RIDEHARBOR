    gap: 3px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1100;
    padding: 4px;
}
/* Perfect 2x2 grid */
.ham-dot {
    width: 8px;
    height: 8px;
    background: #D4AF37;
    border-radius: 50%;
    transition: 0.4s ease;
}
/* Ensure grid structure */
.hamburger span {
    flex: 0 0 40%;
}
.hamburger.open .ham-dot:nth-child(1) {
    transform: translate(6px, 6px) rotate(45deg);
}
.hamburger.open .ham-dot:nth-child(2) {
    transform: translate(-6px, 6px) rotate(-45deg);
}
.hamburger.open .ham-dot:nth-child(3) {
    transform: translate(6px, -6px) rotate(-45deg);
}
.hamburger.open .ham-dot:nth-child(4) {
