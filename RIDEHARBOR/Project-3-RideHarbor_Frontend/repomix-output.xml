    inset: 0;
    background: rgba(0, 0, 0, 0.97);
    backdrop-filter: blur(12px);
    z-index: 9998;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 60px 40px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
}
/* Scroll effect for mobile header */
header.scrolled {
    background: rgba(0, 0, 0, 0.95) !important;
    backdrop-filter: blur(10px) !important;
    -webkit-backdrop-filter: blur(10px) !important;
}
.mobile-menu-overlay.open {
    opacity: 1;
    pointer-events: all;
}
.mobile-menu-close {
    position: absolute;
    top: 22px;
    right: 24px;
    font-size: 26px;
    color: #aaa;
    cursor: pointer;
    transition: color 0.3s;
    z-index: 2;
}
.mobile-menu-close:hover {
    color: #D4AF37;
}
.mobile-nav {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0;
}
.mobile-nav-link {
    display: block;
    font-size: 20px;
    font-weight: 600;
    color: white;
    text-decoration: none;
    letter-spacing: 1px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(212, 175, 55, 0.12);
    opacity: 0;
    transform: translateX(-60px);
    transition: color 0.3s ease;
}
.mobile-nav-link.slide-in {
    animation: slideInLeft 0.45s ease forwards;
}
@keyframes slideInLeft {
    from {
        opacity: 0;
        transform: translateX(-60px);
    }
    to {
        opacity: 1;
        transform: translateX(0);
    }
}
.mobile-nav-link:hover {
    color: #D4AF37;
}
.mobile-nav-link::before {
    content: "";
    display: inline-block;
    width: 0;
    height: 2px;
    background: #D4AF37;
    margin-right: 0;
    vertical-align: middle;
    transition: width 0.3s ease, margin-right 0.3s ease;
}
.mobile-nav-link:hover::before {
    width: 20px;
    margin-right: 10px;
}
.mobile-submenu {
    display: none;
    flex-direction: column;
    padding-left: 20px;
    margin-top: 4px;
    border-left: 2px solid rgba(212, 175, 55, 0.3);
}
.mobile-submenu.open {
    display: flex;
}
.mobile-submenu a {
    color: #bbb;
    text-decoration: none;
    font-size: 16px;
    font-weight: 700;
    padding: 10px 8px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: color 0.3s, padding-left 0.3s;
    opacity: 0;
    animation: slideInLeft 0.35s ease forwards;
}
.mobile-submenu a:hover {
    color: #D4AF37;
    padding-left: 14px;
}
/* ================= SCROLL STATE ================= */
header.scrolled {
    background: rgba(0, 0, 0, 0.95) !important;
    backdrop-filter: blur(10px) !important;
}
/* ================= DYNAMIC CARD STYLES ================= */
.model-card {
    border: 1px solid rgba(212, 175, 55, 0.08);
    transition: transform 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
}
.model-card:hover {
    transform: translateY(-10px);
    border-color: rgba(212, 175, 55, 0.5);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6), 0 0 30px rgba(212, 175, 55, 0.08);
}
/* Gold corner brackets */
.model-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    border-top: 3px solid #D4AF37;
    border-left: 3px solid #D4AF37;
    transition: width 0.4s ease, height 0.4s ease;
    z-index: 5;
}
.model-card::after {
    content: "";
    position: absolute;
    bottom: 0;
    right: 0;
    width: 0;
    height: 0;
    border-bottom: 3px solid #D4AF37;
    border-right: 3px solid #D4AF37;
    transition: width 0.4s ease, height 0.4s ease;
    z-index: 5;
}
.model-card:hover::before,
.model-card:hover::after {
    width: 36px;
    height: 36px;
}
/* Image dim + zoom on hover */
.model-card:hover .image-wrapper img {
    transform: scale(1.1);
    filter: brightness(0.55);
}
/* Overlay Rent Now button */
.card-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    z-index: 4;
}
.model-card:hover .card-overlay {
    opacity: 1;
    transform: translateY(0);
}
.overlay-rent-btn {
    padding: 11px 30px;
    background: transparent;
    border: 1px solid #D4AF37;
    color: #D4AF37;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
}
.overlay-rent-btn:hover {
    background: #D4AF37;
    color: black;
}
/* Title turns gold on hover */
.model-card:hover .model-info h3 {
    color: #D4AF37;
}
.model-card:nth-child(1) {
    animation-delay: 0.05s;
}
.model-card:nth-child(2) {
    animation-delay: 0.12s;
}
.model-card:nth-child(3) {
    animation-delay: 0.19s;
}
.model-card:nth-child(4) {
    animation-delay: 0.26s;
}
.model-card:nth-child(5) {
    animation-delay: 0.33s;
}
.model-card:nth-child(6) {
    animation-delay: 0.40s;
}
.model-card:nth-child(7) {
    animation-delay: 0.47s;
}
.model-card:nth-child(8) {
    animation-delay: 0.54s;
}
@keyframes cardReveal {
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
/* ================= GOLD BUTTON ================= */
.gold-btn {
    padding: 8px 18px;
    background: #D4AF37;
    border: none;
    border-radius: 5px;
    color: black;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: 0.3s;
    text-decoration: none;
    display: inline-block;
}
.gold-btn:hover {
    background: #b9972f;
}
/* ================= LOGIN MODAL ================= */
.luxury-modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    justify-content: center;
    align-items: center;
    z-index: 9999;
}
.luxury-modal-content {
    width: 400px;
    padding: 40px;
    background: linear-gradient(145deg, #111, #1c1c1c);
    border-radius: 16px;
    border: 1px solid rgba(255, 215, 0, 0.2);
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.8);
    position: relative;
    animation: modalFade 0.4s ease;
}
.modal-title {
    color: #fff;
    text-align: center;
    margin-bottom: 5px;
    font-size: 26px;
}
.modal-subtitle {
    text-align: center;
    color: #aaa;
    font-size: 14px;
    margin-bottom: 30px;
}
.input-group {
    position: relative;
    margin-bottom: 25px;
}
.input-group input {
    width: 100%;
    padding: 12px;
    background: #111;
    border: 1px solid #333;
    border-radius: 6px;
    color: white;
    outline: none;
}
.input-group label {
    position: absolute;
    left: 12px;
    top: 12px;
    color: #888;
    font-size: 14px;
    pointer-events: none;
    transition: 0.3s;
}
.input-group input:focus+label,
.input-group input:valid+label {
    top: -8px;
    font-size: 11px;
    color: gold;
}
.modal-btn {
    width: 100%;
    margin-top: 10px;
}
.otp-section {
    display: none;
    margin-top: 20px;
}
.close-btn {
    position: absolute;
    right: 15px;
    top: 10px;
    font-size: 26px;
    color: #888;
    cursor: pointer;
}
.close-btn:hover {
    color: white;
}
@keyframes modalFade {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
/* ================= FOOTER REVEAL EFFECT ================= */
/* Push content above footer */
.page-content {
    position: relative;
    z-index: 2;
    background: #0f0f0f;
}
/* Footer stays behind */
.luxury-footer {
    position: sticky;
    bottom: 0;
    z-index: 1;
}
/* =========================================================*/
#bookingFormModal input,
#bookingFormModal select {
    width: 100%;
    margin-bottom: 12px;
    padding: 12px;
    background: #111;
    border: 1px solid #333;
    color: white;
    border-radius: 6px;
    outline: none;
    font-size: 14px;
    box-sizing: border-box;
}
#bookingFormModal input:focus,
#bookingFormModal select:focus {
    border-color: #D4AF37;
    box-shadow: 0 0 8px rgba(212, 175, 55, 0.4);
}
#bookingFormModal select {
    appearance: none;
    -webkit-appearance: none;
    background-image: linear-gradient(45deg, transparent 50%, #D4AF37 50%),
        linear-gradient(135deg, #D4AF37 50%, transparent 50%);
    background-position: calc(100% - 18px) calc(50% - 3px),
        calc(100% - 12px) calc(50% - 3px);
    background-size: 6px 6px;
    background-repeat: no-repeat;
    cursor: pointer;
}
#bookingFormModal select option {
    background: #111;
    color: white;
}
#bf_car[readonly] {
    border-color: rgba(212, 175, 55, 0.4);
    background: #1a1a1a !important;
}
.luxury-modal-content {
    max-height: 90vh;
    overflow-y: auto;
}
/*TABLET  ≤ 960px
   ========================================================= */
@media (max-width: 960px) {
    header {
        padding: 14px 24px;
    }
    nav a {
        margin-left: 16px;
        font-size: 13px;
    }
    .logo {
        font-size: 22px;
    }
    .signin a {
