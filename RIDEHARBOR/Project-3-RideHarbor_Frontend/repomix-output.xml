/* ================= HAMBURGER (MOBILE) ================= */
.hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    cursor: pointer;
    gap: 3px;
    flex-wrap: wrap;
    z-index: 1100;
    position: relative;
    margin-left: 12px;
}

.ham-dot {
    width: 8px;
    height: 8px;
    background: #D4AF37;
    border-radius: 50%;
    transition: transform 0.4s ease, opacity 0.3s ease, background 0.3s ease;
    display: inline-block;
}

/* 2x2 grid of dots */
.hamburger {
    display: none;
    width: 36px;
    height: 36px;
    display: none;
    flex-wrap: wrap;
    gap: 3px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1100;
    padding: 4px;
}

/* Active state: rotate into X pattern */
.hamburger.open .ham-dot:nth-child(1) {
    transform: translate(7px, 7px) rotate(45deg) scaleX(1.6);
    border-radius: 2px;
}

.hamburger.open .ham-dot:nth-child(2) {
    transform: translate(-7px, 7px) rotate(-45deg) scaleX(1.6);
    border-radius: 2px;
}

.hamburger.open .ham-dot:nth-child(3) {
    transform: translate(7px, -7px) rotate(-45deg) scaleX(1.6);
    border-radius: 2px;
}

.hamburger.open .ham-dot:nth-child(4) {
    transform: translate(-7px, -7px) rotate(45deg) scaleX(1.6);
    border-radius: 2px;
}

/* ================= MOBILE MENU OVERLAY ================= */
.mobile-menu-overlay {
    height: 100dvh;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.97);
    backdrop-filter: blur(12px);
    z-index: 9998;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px 40px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
}

.mobile-menu-overlay.open {
    opacity: 1;
    pointer-events: all;
}

/* Close button */
.mobile-menu-close {
    position: absolute;
    top: 22px;
    right: 24px;
    font-size: 26px;
    color: #aaa;
    cursor: pointer;
    transition: color 0.3s;
    z-index: 2;
}

.mobile-menu-close:hover {
    color: #D4AF37;
}

/* Nav links */
.mobile-nav {
    max-width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0;
}

.mobile-nav-link {
    display: block;
    font-size: 20px;
    font-weight: 600;
    color: white;
    text-decoration: none;
    letter-spacing: 1px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(212, 175, 55, 0.12);
    opacity: 0;
    transform: translateX(-60px);
    transition: color 0.3s ease;
    /* Staggered slide-in handled by JS adding .slide-in */
}

.mobile-nav-link.slide-in {
    animation: slideInLeft 0.45s ease forwards;
}

@keyframes slideInLeft {
    from {
        opacity: 0;
        transform: translateX(-60px);
    }

    to {
        opacity: 1;
        transform: translateX(0);
    }
}

.mobile-nav-link:hover {
    color: #D4AF37;
}

/* Gold accent on active */
.mobile-nav-link::before {
    content: "";
    display: inline-block;
    width: 0;
    height: 2px;
    background: #D4AF37;
    margin-right: 0;
    vertical-align: middle;
    transition: width 0.3s ease, margin-right 0.3s ease;
}

.mobile-nav-link:hover::before {
    width: 20px;
    margin-right: 10px;
}

/* Submenu */
.mobile-submenu {
    display: none;
    flex-direction: column;
    padding-left: 20px;
    margin-top: 4px;
    gap: 0;
    border-left: 2px solid rgba(212, 175, 55, 0.3);
}

.mobile-submenu.open {
    display: flex;
}

.mobile-submenu a {
    color: #bbb;
    text-decoration: none;
    font-size: 16px;
    font-weight: 700;
    padding: 10px 8px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    transition: color 0.3s, padding-left 0.3s;
    opacity: 0;
    animation: slideInLeft 0.35s ease forwards;
}

.mobile-submenu a:hover {
    color: #D4AF37;
    padding-left: 14px;
}

