nav {
    flex: 1;
    gap: 1%;
    max-width: 35%;
}
nav a {
    margin-left: 30px;
    text-decoration: none;
    color: white;
    transition: 0.3s;
}
nav a:hover {
    color: #D4AF37;
}
/* Perfect center logo */
.logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
}
.signin {
    max-width: 10%;
    flex: 1;
    display: flex;
    justify-content: flex-end;
    margin-right: 3%;
}
.signin a {
    padding: 8px 18px;
    /* reduced size */
    background: #D4AF37;
    color: black;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    /* smaller text */
    border-radius: 5px;
    transition: 0.3s ease;
}
.signin a:hover {
    background: #b9972f;
}
/* ================= EXPLORE DROPDOWN ================= */
nav {
    display: flex;
    align-items: center;
}
.dropdown {
    position: relative;
}
/* Hide menu initially */
.dropdown-menu {
    position: absolute;
    top: 40px;
    left: 0;
    min-width: 230px;
    background: rgba(20, 20, 20, 0.95);
    backdrop-filter: blur(12px);
    border-radius: 12px;
    padding: 15px 0;
    border: 1px solid rgba(212, 175, 55, 0.15);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s ease;
}
/* Show on hover */
.dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}
/* Dropdown links */
.dropdown-menu a {
    display: block;
    padding: 12px 25px;
    color: #ccc;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
}
/* Hover effect */
.dropdown-menu a:hover {
    background: rgba(212, 175, 55, 0.1);
    color: #D4AF37;
    padding-left: 30px;
}
/* ================= PREMIUM BANNER SLIDER ================= */
.banner {
