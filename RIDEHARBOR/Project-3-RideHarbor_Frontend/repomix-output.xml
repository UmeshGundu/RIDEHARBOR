<file path="css/porsche.css">
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}
body {
    background: #0f0f0f;
    color: white;
    scroll-behavior: smooth;
}
body::before {
    content: "";
    position: fixed;
    top: -200px;
    left: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.08), transparent 70%);
    z-index: -1;
}
/* ================= HEADER ================= */
header {
    position: fixed;
    width: 100%;
    top: 0;
    left: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    padding: 20px 0px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 1000;
}
.logo {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: 2px;
    font-family: 'Montserrat', sans-serif;
    color: #ffffff;
}
.logo span {
    color: #D4AF37;
    /* modern deep blue */
}
/* Keep nav left */
nav {
    flex: 1;
    gap: 1%;
    max-width: 35%;
}
nav a {
    margin-left: 30px;
    text-decoration: none;
    color: white;
    transition: 0.3s;
}
nav a:hover {
    color: #D4AF37;
}
/* Perfect center logo */
.logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
}
.signin {
    max-width: 10%;
    flex: 1;
    display: flex;
    justify-content: flex-end;
    margin-right: 3%;
}
.signin a {
    padding: 8px 18px;
    /* reduced size */
    background: #D4AF37;
    color: black;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    /* smaller text */
    border-radius: 5px;
    transition: 0.3s ease;
}
.signin a:hover {
    background: #b9972f;
}
/* ================= EXPLORE DROPDOWN ================= */
nav {
    display: flex;
    align-items: center;
}
.dropdown {
    position: relative;
}
/* Hide menu initially */
.dropdown-menu {
    position: absolute;
    top: 40px;
    left: 0;
    min-width: 230px;
    background: rgba(20, 20, 20, 0.95);
    backdrop-filter: blur(12px);
    border-radius: 12px;
    padding: 15px 0;
    border: 1px solid rgba(212, 175, 55, 0.15);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s ease;
}
/* Show on hover */
.dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}
/* Dropdown links */
.dropdown-menu a {
    display: block;
    padding: 12px 25px;
    color: #ccc;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
}
/* Hover effect */
.dropdown-menu a:hover {
    background: rgba(212, 175, 55, 0.1);
    color: #D4AF37;
    padding-left: 30px;
}
/* ================= PREMIUM BANNER SLIDER ================= */
.banner {
    height: 70vh;
    margin-top: 80px;
    position: relative;
    background-image: url('/img/porscheimages/porschebannerimg.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}
/* Optional dark overlay */
.banner::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
}
/* Gold line under banner */
.banner::before {
    content: "";
    position: absolute;
    bottom: -2px;
    /* sits just below banner */
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 2px;
    background: linear-gradient(to right,
            transparent,
            #D4AF37,
            transparent);
}
.banner-content {
    position: relative;
    z-index: 2;
    text-align: center;
    top: 50%;
    transform: translateY(-50%);
}
.banner-content h1 {
    font-size: 80px;
    font-family: 'Playfair Display', serif;
    letter-spacing: 6px;
    margin-bottom: 20px;
}
.banner-content p {
    font-size: 18px;
    color: #D4AF37;
    margin-bottom: 30px;
}
.banner-btn {
    padding: 12px 30px;
    border: 1px solid #D4AF37;
    color: #D4AF37;
    text-decoration: none;
    transition: 0.3s ease;
}
.banner-btn:hover {
    background: #D4AF37;
    color: black;
}
/* ================ Brand Intro ================*/
.brand-intro {
    text-align: center;
    padding: 180px 10% 10px;
}
.brand-intro h2 {
    font-size: 45px;
    color: #D4AF37;
    margin-bottom: 10px;
    font-family: 'Playfair Display', serif;
    letter-spacing: 2px;
}
.brand-intro p {
    color: #bbb;
    font-size: 16px;
    max-width: 700px;
    margin: auto;
}
/* ================ Models Section ================*/
#models-section {
    padding: 100px 8%;
    background: #0f0f0f;
}
#models-section::after {
    content: "";
    display: block;
    width: 80%;
    height: 1px;
    margin: 100px auto 0;
    background: linear-gradient(to right,
            transparent,
            rgba(212, 175, 55, 0.6),
            transparent);
}
/* 4 Equal Columns */
.models-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
}
/* Remove box feel */
.model-card {
    position: relative;
    overflow: hidden;
}
.model-card {
    transition: transform 0.4s ease, filter 0.4s ease;
}
.model-card:hover {
    transform: translateY(-8px);
    filter: brightness(1.05);
}
/* Image wrapper */
.image-wrapper {
    overflow: hidden;
}
/* Big premium image */
.image-wrapper img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    transition: transform 0.6s ease;
}
/* Smooth zoom effect */
.model-card:hover img {
    transform: scale(1.08);
}
/* Info section */
.model-info {
    padding: 20px 5px 10px 5px;
}
/* Title with gold underline animation */
.model-info h3 {
    font-size: 20px;
    color: white;
    position: relative;
    margin-bottom: 8px;
}
/* Animated underline */
.model-info h3::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 2px;
    background: #D4AF37;
    transition: width 0.4s ease;
}
.model-card:hover h3::after {
    width: 100%;
}
/* Specs */
.model-info p {
    font-size: 13px;
    color: #aaa;
    margin-bottom: 15px;
}
/* Bottom row layout */
.bottom-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
/* Price */
.price {
    color: #D4AF37;
    font-weight: 600;
    font-size: 14px;
}
/* Minimal Button */
.model-card button {
    background: transparent;
    border: 1px solid #D4AF37;
    color: #D4AF37;
    padding: 6px 16px;
    font-size: 13px;
    cursor: pointer;
    transition: 0.3s ease;
}
.model-card button:hover {
    background: #D4AF37;
    color: black;
}
/* ================================*/
.performance-strip {
    padding: 100px 8%;
    text-align: center;
    background: linear-gradient(to right, #0f0f0f, #141414);
}
.performance-strip h2 {
    font-size: 35px;
    color: #D4AF37;
    margin-bottom: 20px;
}
.performance-strip p {
    color: #bbb;
}
/* ================= FOOTER ================= */
.luxury-footer {
    background: #111;
    padding: 80px 8% 30px;
    border-top: 1px solid rgba(212, 175, 55, 0.15);
}
.footer-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 60px;
    margin-bottom: 50px;
}
/* Brand */
.footer-brand h2 {
    font-size: 28px;
    margin-bottom: 15px;
}
.footer-brand span {
    color: #D4AF37;
}
.footer-brand p {
    color: #aaa;
    font-size: 14px;
    line-height: 1.6;
}
/* Links */
.footer-links h4,
.footer-contact h4 {
    margin-bottom: 20px;
    color: #D4AF37;
    font-size: 16px;
    letter-spacing: 1px;
}
.footer-links a {
    display: block;
    color: #bbb;
    text-decoration: none;
    margin-bottom: 10px;
    font-size: 14px;
    transition: 0.3s;
}
.footer-links a:hover {
    color: #D4AF37;
    padding-left: 5px;
}
/* Contact */
.footer-contact p {
    color: #bbb;
    font-size: 14px;
    margin-bottom: 10px;
}
/* Bottom Bar */
.footer-bottom {
    text-align: center;
    padding-top: 25px;
    border-top: 2px solid rgba(255, 255, 255, 0.05);
    font-size: 13px;
    color: #777;
}
/* ================= HAMBURGER ================= */
.hamburger {
    display: none;
    width: 36px;
    height: 30px;
    flex-wrap: wrap;
    gap: 3px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1100;
    padding: 4px;
}
/* Perfect 2x2 grid */
.ham-dot {
    width: 8px;
    height: 8px;
    background: #D4AF37;
    border-radius: 50%;
    transition: 0.4s ease;
}
/* Ensure grid structure */
.hamburger span {
    flex: 0 0 40%;
}
.hamburger.open .ham-dot:nth-child(1) {
    transform: translate(6px, 6px) rotate(45deg);
}
.hamburger.open .ham-dot:nth-child(2) {
    transform: translate(-6px, 6px) rotate(-45deg);
}
.hamburger.open .ham-dot:nth-child(3) {
    transform: translate(6px, -6px) rotate(-45deg);
}
.hamburger.open .ham-dot:nth-child(4) {
    transform: translate(-6px, -6px) rotate(45deg);
}
/* ================= MOBILE OVERLAY ================= */
.mobile-menu-overlay {
    height: 100dvh;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.97);
    backdrop-filter: blur(12px);
    z-index: 9998;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 60px 40px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.4s ease;
}
/* Scroll effect for mobile header */
