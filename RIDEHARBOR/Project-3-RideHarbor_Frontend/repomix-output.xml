<file path="css/mercedes.css">
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Poppins', sans-serif;
}
body {
    background: #0f0f0f;
    color: white;
    scroll-behavior: smooth;
}
body::before {
    content: "";
    position: fixed;
    top: -200px;
    left: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.08), transparent 70%);
    z-index: -1;
}
/* ================= HEADER ================= */
header {
    position: fixed;
    width: 100%;
    top: 0;
    left: 0;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    padding: 20px 0px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 1000;
}
.logo {
    font-size: 26px;
    font-weight: 600;
    letter-spacing: 2px;
    font-family: 'Montserrat', sans-serif;
    color: #ffffff;
}
.logo span {
    color: #D4AF37;
    /* modern deep blue */
}
/* Keep nav left */
nav {
    flex: 1;
    gap: 1%;
    max-width: 35%;
}
nav a {
    margin-left: 30px;
    text-decoration: none;
    color: white;
    transition: 0.3s;
}
nav a:hover {
    color: #D4AF37;
}
/* Perfect center logo */
.logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
}
.signin {
    max-width: 10%;
    flex: 1;
    display: flex;
    justify-content: flex-end;
    margin-right: 3%;
}
.signin a {
    padding: 8px 18px;
    /* reduced size */
    background: #D4AF37;
    color: black;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    /* smaller text */
    border-radius: 5px;
    transition: 0.3s ease;
}
.signin a:hover {
    background: #b9972f;
}
/* ================= EXPLORE DROPDOWN ================= */
nav {
    display: flex;
    align-items: center;
}
.dropdown {
    position: relative;
}
/* Hide menu initially */
.dropdown-menu {
    position: absolute;
    top: 40px;
    left: 0;
    min-width: 230px;
    background: rgba(20, 20, 20, 0.95);
    backdrop-filter: blur(12px);
    border-radius: 12px;
    padding: 15px 0;
    border: 1px solid rgba(212, 175, 55, 0.15);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6);
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: all 0.3s ease;
}
/* Show on hover */
.dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
}
/* Dropdown links */
.dropdown-menu a {
    display: block;
    padding: 12px 25px;
    color: #ccc;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
}
/* Hover effect */
.dropdown-menu a:hover {
    background: rgba(212, 175, 55, 0.1);
    color: #D4AF37;
    padding-left: 30px;
}
/* ================= PREMIUM BANNER SLIDER ================= */
.banner {
    height: 70vh;
    margin-top: 80px;
    position: relative;
    background-image: url('/img/mercedesimages/benzbannerimg.jpg');
    background-size: cover;
    background-position: center 40%;
    background-repeat: no-repeat;
}
/* Optional dark overlay */
.banner::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
}
/* Gold line under banner */
.banner::before {
    content: "";
    position: absolute;
    bottom: -2px;
    /* sits just below banner */
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 2px;
    background: linear-gradient(to right,
            transparent,
            #D4AF37,
            transparent);
}
.banner-content {
    position: relative;
    z-index: 2;
    text-align: center;
    top: 50%;
    transform: translateY(-50%);
}
.banner-content h1 {
    font-size: 80px;
    font-family: 'Playfair Display', serif;
    letter-spacing: 6px;
    margin-bottom: 20px;
}
.banner-content p {
    font-size: 18px;
    color: #D4AF37;
    margin-bottom: 30px;
}
.banner-btn {
    padding: 12px 30px;
    border: 1px solid #D4AF37;
    color: #D4AF37;
    text-decoration: none;
    transition: 0.3s ease;
}
.banner-btn:hover {
    background: #D4AF37;
    color: black;
}
/* ================ Brand Intro ================*/
.brand-intro {
    text-align: center;
    padding: 180px 10% 10px;
}
.brand-intro h2 {
    font-size: 45px;
    color: #D4AF37;
