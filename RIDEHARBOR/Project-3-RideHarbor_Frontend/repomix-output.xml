    .model-card:active {
        transform: scale(0.96);
    }
    .model-card {
        opacity: 0;
        transform: translateY(50px) scale(0.96);
        transition: all 0.6s ease;
    }
    .model-card.show {
        opacity: 1;
        transform: translateY(0) scale(1);
    }
    .models-grid {
        grid-template-columns: 1fr;
    }
}
