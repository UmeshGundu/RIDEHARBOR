.model-card {
    transition: transform 0.4s ease, filter 0.4s ease;
}
.model-card:hover {
    transform: translateY(-8px);
    filter: brightness(1.05);
}
/* Image wrapper */
.image-wrapper {
    overflow: hidden;
}
/* Big premium image */
.image-wrapper img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    transition: transform 0.6s ease;
}
/* Smooth zoom effect */
.model-card:hover img {
    transform: scale(1.08);
}
/* Info section */
.model-info {
    padding: 20px 5px 10px 5px;
}
/* Title with gold underline animation */
.model-info h3 {
    font-size: 20px;
    color: white;
    position: relative;
    margin-bottom: 8px;
}
/* Animated underline */
.model-info h3::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 0;
    height: 2px;
    background: #D4AF37;
    transition: width 0.4s ease;
}
.model-card:hover h3::after {
    width: 100%;
}
/* Specs */
.model-info p {
    font-size: 13px;
    color: #aaa;
    margin-bottom: 15px;
}
/* Bottom row layout */
.bottom-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
/* Price */
.price {
    color: #D4AF37;
    font-weight: 600;
    font-size: 14px;
}
/* Minimal Button */
.model-card button {
    background: transparent;
    border: 1px solid #D4AF37;
    color: #D4AF37;
    padding: 6px 16px;
    font-size: 13px;
    cursor: pointer;
    transition: 0.3s ease;
}
.model-card button:hover {
    background: #D4AF37;
    color: black;
}
/* ================================*/
.performance-strip {
    padding: 100px 8%;
    text-align: center;
    background: linear-gradient(to right, #0f0f0f, #141414);
}
.performance-strip h2 {
    font-size: 35px;
    color: #D4AF37;
    margin-bottom: 20px;
}
.performance-strip p {
    color: #bbb;
}
/* ================= FOOTER ================= */
.luxury-footer {
    background: #111;
    padding: 80px 8% 30px;
    border-top: 1px solid rgba(212, 175, 55, 0.15);
}
.footer-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 60px;
    margin-bottom: 50px;
}
/* Brand */
.footer-brand h2 {
    font-size: 28px;
    margin-bottom: 15px;
}
.footer-brand span {
    color: #D4AF37;
}
.footer-brand p {
    color: #aaa;
    font-size: 14px;
    line-height: 1.6;
}
/* Links */
.footer-links h4,
.footer-contact h4 {
    margin-bottom: 20px;
    color: #D4AF37;
    font-size: 16px;
    letter-spacing: 1px;
}
.footer-links a {
    display: block;
    color: #bbb;
    text-decoration: none;
    margin-bottom: 10px;
    font-size: 14px;
    transition: 0.3s;
}
.footer-links a:hover {
    color: #D4AF37;
    padding-left: 5px;
}
/* Contact */
.footer-contact p {
    color: #bbb;
    font-size: 14px;
    margin-bottom: 10px;
}
/* Bottom Bar */
.footer-bottom {
    text-align: center;
    padding-top: 25px;
    border-top: 2px solid rgba(255, 255, 255, 0.05);
    font-size: 13px;
    color: #777;
}
/* ================= HAMBURGER ================= */
.hamburger {
    display: none;
    width: 36px;
    height: 30px;
    flex-wrap: wrap;
    gap: 3px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1100;
    padding: 4px;
}
/* Perfect 2x2 grid */
.ham-dot {
    width: 8px;
    height: 8px;
    background: #D4AF37;
    border-radius: 50%;
    transition: 0.4s ease;
}
/* Ensure grid structure */
.hamburger span {
    flex: 0 0 40%;
}
.hamburger.open .ham-dot:nth-child(1) {
    transform: translate(6px, 6px) rotate(45deg);
}
.hamburger.open .ham-dot:nth-child(2) {
    transform: translate(-6px, 6px) rotate(-45deg);
}
.hamburger.open .ham-dot:nth-child(3) {
    transform: translate(6px, -6px) rotate(-45deg);
}
.hamburger.open .ham-dot:nth-child(4) {
    transform: translate(-6px, -6px) rotate(45deg);
}
/* ================= MOBILE OVERLAY ================= */
