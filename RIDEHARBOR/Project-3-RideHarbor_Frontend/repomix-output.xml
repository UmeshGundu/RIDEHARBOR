}
.mobile-nav-link:hover {
    color: #D4AF37;
}
.mobile-nav-link::before {
    content: "";
    display: inline-block;
    width: 0;
    height: 2px;
    background: #D4AF37;
    margin-right: 0;
    vertical-align: middle;
    transition: width 0.3s ease, margin-right 0.3s ease;
}
.mobile-nav-link:hover::before {
    width: 20px;
    margin-right: 10px;
}
.mobile-submenu {
