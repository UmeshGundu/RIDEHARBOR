.leftPosition {
    transform: translate(calc(-50% - 250px), calc(-50% + 40px)) scale(0.8);
    z-index: 3;
    opacity: 0.6;
}

/* Right */
.rightPosition {
    transform: translate(calc(-50% + 250px), calc(-50% + 40px)) scale(0.8);
    z-index: 3;
    opacity: 0.6;
}

